rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return firestore.get(
        /databases/(default)/documents/usuarios/$(request.auth.uid)
      ).data;
    }

    function roleText() {
      let d = userProfile();
      return (d.get('puesto', '') + ' ' + d.get('role', '')).lower();
    }

    function canAccessPatronCertificates() {
      return isSignedIn() && roleText().matches(
        '.*(calidad|quality|admin|gerente|manager|metrologo|metr[oó]logo|tecnico|t[eé]cnico|logistica).*'
      );
    }

    function canWritePatronCertificates() {
      return isSignedIn() && roleText().matches(
        '.*(calidad|quality|admin|gerente|manager|metrologo|metr[oó]logo|tecnico|t[eé]cnico).*'
      );
    }

    function isAllowedCertificateUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
          'application/pdf|image/jpeg|image/png|image/webp'
        );
    }

    /** UUID de patrón en legacy certificados/{uuid}/… — no confundir con carpeta de técnico. */
    function isPatronUuidFolder(name) {
      return name.matches(
        '^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$'
      );
    }

    // Drive PDF certificados — listar/leer (igual que worksheets; incluye raíz certificados/)
    match /certificados/{allPaths=**} {
      allow read, list: if isSignedIn();
    }

    // Drive PDF — escribir solo en carpetas de técnico (no UUID de patrón legacy)
    match /certificados/{folder}/{allPaths=**} {
      allow create, update, delete: if isSignedIn() && !isPatronUuidFolder(folder);
    }

    match /certificados/{folder} {
      allow create, update, delete: if isSignedIn() && !isPatronUuidFolder(folder);
    }

    // Certificados de patrones — calibraciones/{patronId}/{archivo} o subcarpetas por parte
    match /calibraciones/{patronId}/{fileName} {
      allow read: if canAccessPatronCertificates();
      allow create, update: if canWritePatronCertificates()
        && isAllowedCertificateUpload();
      allow delete: if canWritePatronCertificates()
        && roleText().matches('.*(calidad|quality|admin|gerente|manager).*');
    }

    match /calibraciones/{patronId}/{parteId}/{fileName} {
      allow read: if canAccessPatronCertificates();
      allow create, update: if canWritePatronCertificates()
        && isAllowedCertificateUpload();
      allow delete: if canWritePatronCertificates()
        && roleText().matches('.*(calidad|quality|admin|gerente|manager).*');
    }

    // Legacy: certificados/{patronUuid}/{archivo} — certificados de patrones (no Drive técnico)
    match /certificados/{patronId}/{fileName} {
      allow read: if canAccessPatronCertificates();
      allow create, update: if canWritePatronCertificates()
        && isAllowedCertificateUpload()
        && isPatronUuidFolder(patronId);
      allow delete: if canWritePatronCertificates()
        && roleText().matches('.*(calidad|quality|admin|gerente|manager).*')
        && isPatronUuidFolder(patronId);
    }

    // Hojas de trabajo / Drive worksheets
    match /worksheets/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /servicios/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /formatos_master/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Solicitudes de vacaciones (PDF AG-ADM-F12) — lectura app; escritura vía Functions Admin
    match /vacaciones/{solicitudId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow delete: if isSignedIn();
    }
  }
}
